      "mcp__anki__card_reviews",
      "mcp__anki__get_reviews_of_cards",
      "mcp__anki__get_latest_review_id",
      "mcp__anki__sync",
      "Bash(python3 .claude/mem-bank/big-bank.py:*)",
      "Bash(python3 .claude/mem-bank/small-job-worker.py*)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git check-ignore *)",
      "Write(**/*.compiled.md)",
      "Write(**/*.preprocessed.md)",
      "Write(/tmp/card-edit-context.md)",
      "Read(/tmp/card-edit-context.md)",
      "Write(/tmp/card-input.txt)",
      "Edit(modes/world-adoption/outbound/ledger.md)",
      "Bash(claude -p --bare *)",
      "Bash(python3 .claude/skills/youtube-extract/extract.py:*)",
      "Bash(plugins/context-compiler/.venv/bin/python3 plugins/context-compiler/preprocess.py:*)",
      "Bash(plugins/context-compiler/.venv/bin/python3 plugins/context-compiler/include_graph.py:*)",
      "Bash(plugins/context-compiler/.venv/bin/python3 plugins/context-compiler/compiled-is-fresh.py:*)",
      "Bash(plugins/anki-mcp/.venv/bin/python3 plugins/anki-mcp/skills/process-user-feedback-on-deck/extract.py:*)",
      "Bash(plugins/anki-mcp/.venv/bin/python3 plugins/anki-mcp/skills/process-user-feedback-on-deck/confirm.py:*)",
      "Bash(plugins/anki-mcp/.venv/bin/python3 plugins/anki-mcp/skills/process-user-feedback-on-deck/apply.py:*)",
      "Bash(plugins/anki-mcp/.venv/bin/python3 plugins/anki-mcp/skills/process-user-feedback-on-deck/edit.py:*)",
      "Bash(plugins/anki-mcp/.venv/bin/python3 plugins/anki-mcp/skills/process-user-feedback-on-deck/reset-test-deck.py:*)",
      "Bash(cp groves/**)",
      "Bash(cp ~/Pictures/screenshots/*)"
    ],
    "_note_external_writes": [
      "Writes to /tmp or ANY path outside the project root always trigger a manual write-confirmation, regardless of a Write(...) allow rule.",
      "A project-committed .claude/settings.json cannot grant out-of-tree write access (security): additionalDirectories only lifts this when set in PERSONAL settings (.claude/settings.local.json or ~/.claude/settings.json), not committed project settings.",
      "Reads are different — Read(//abs/path) works (double-slash = filesystem-absolute).",
      "Fix we adopted: keep script artifacts inside the project tree, see plugins/anki-mcp .artifacts/ (gitignored).",
      "In-tree is NOT auto-approved: a file written via a python script (Bash) rides the Bash allow rule, but a file written via the Write TOOL still needs its own Write(...) allow rule. In-tree only avoids the hard out-of-tree block. The feedback pipeline writes all its artifacts from Python (extract/edit/apply), so it needs no Write(...) rule for them.",
      "The Bash venv rules above are enumerated one-per-script (interpreter + full script path + :*).",
      "A Bash allow-rule's :* wildcard only matches at whole-token boundaries — a mid-path prefix like '.../python3 plugins/anki-mcp/:*' never matches a real script path, so each script needs its own entry. Adding a new venv script means adding its own allow line."
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/turn-tracker.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/log-instructions-loaded.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/log-permission-request.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/system/scm-integration/gh-issue-label-gate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/notify-meta-read.py"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/notify-context-read.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/debug/log-session-end.py"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/mem-bank/small-bank.py --subscriptions \"$CLAUDE_PROJECT_DIR\"/.claude/mem-bank/subscriptions.json"
          }
        ]
      }
    ]
  }
}
