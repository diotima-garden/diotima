{
  "permissions": {
    "allow": [
      "mcp__anki__find_cards",
      "mcp__anki__find_flagged_cards",
      "mcp__anki__find_notes",
      "mcp__anki__cards_info",
      "mcp__anki__notes_info",
      "mcp__anki__cards_to_notes",
      "mcp__anki__get_flagged_notes",
      "mcp__anki__get_all_notes",
      "mcp__anki__add_notes",
      "mcp__anki__can_add_notes",
      "mcp__anki__update_note_fields",
      "mcp__anki__update_note",
      "mcp__anki__set_card_flag",
      "mcp__anki__get_tags",
      "mcp__anki__add_tags",
      "mcp__anki__deck_names",
      "mcp__anki__deck_stats",
      "mcp__anki__get_decks",
      "mcp__anki__create_deck",
      "mcp__anki__get_deck_config",
      "mcp__anki__save_deck_config",
      "mcp__anki__export_deck",
      "mcp__anki__import_package",
      "mcp__anki__are_suspended",
      "mcp__anki__are_due",
      "mcp__anki__get_intervals",
      "mcp__anki__unsuspend_cards",
      "mcp__anki__model_names",
      "mcp__anki__model_field_names",
      "mcp__anki__model_templates",
      "mcp__anki__model_styling",
      "mcp__anki__store_media_file",
      "mcp__anki__retrieve_media_file",
      "mcp__anki__get_media_files_names",
      "mcp__anki__get_media_dir_path",
      "mcp__anki__get_collection_stats",
      "mcp__anki__card_reviews",
      "mcp__anki__get_reviews_of_cards",
      "mcp__anki__get_latest_review_id",
      "mcp__anki__sync",
      "Bash(python3 .claude/scripts/compiled-is-fresh.py:*)",
      "Bash(python3 .claude/scripts/depolymorphize.py:*)",
      "Bash(python3 .claude/scripts/find-inheritables.py:*)",
      "Bash(python3 .claude/mem-bank/big-bank.py:*)",
      "Bash(python3 .claude/mem-bank/small-job-worker.py*)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git check-ignore *)",
      "Write(decks/**/compiled.md)",
      "Write(decks/**/depolymorphized.md)",
      "Read(decks/**/compiled.md)",
      "Read(decks/**/context.md)",
      "Write(/tmp/card-edit-context.md)",
      "Read(/tmp/card-edit-context.md)",
      "Write(/tmp/card-input.txt)",
      "Write(/tmp/card-generation-context.md)",
      "Read(/tmp/card-generation-context.md)",
      "Bash(claude -p --bare *)",
      "Write(.claude/health-agent/health-findings.jsonl)",
      "Bash(python3 .claude/skills/youtube-extract/extract.py:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/health-agent/hooks/observe-session-health.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/health-agent/hooks/detect-health-issues.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/turn-tracker.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/health-agent/hooks/surface-session-health.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/log-instructions-loaded.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/log-permission-request.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/health-agent/hooks/log-permission-request.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/notify-meta-read.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/notify-context-read.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/debug/log-session-end.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/mem-bank/small-bank.py --subscriptions .claude/mem-bank/subscriptions.json"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/health-agent/hooks/observe-skill-start-natural.py"
          }
        ]
      }
    ]
  }
}
